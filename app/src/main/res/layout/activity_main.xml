<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Connection Status -->
        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:text="Disconnected"
            android:textColor="#FFB71C1C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Gateway URL -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:hintEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/gatewayUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gateway URL (e.g. ws://192.168.50.233:18789)"
                android:inputType="textUri"
                android:text="ws://192.168.50.233:18789" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bootstrap Token -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:hintEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bootstrapTokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Bootstrap Token (optional)"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Connect/Disconnect Button -->
        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Connect" />

        <!-- Service Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/accessibilityButton"
                style="@style/Widget.AppCompat.Button.Colored"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="Accessibility" />

            <Button
                android:id="@+id/screenCaptureButton"
                style="@style/Widget.AppCompat.Button.Colored"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="Screen Capture" />

        </LinearLayout>

        <!-- Device Info Section -->
        <TextView
            android:id="@+id/deviceInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:text="Device: ..."
            android:textSize="12sp" />

        <!-- Status Log -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status Log"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="4dp"
            android:background="#FF1A1A1A"
            android:padding="8dp">

            <TextView
                android:id="@+id/statusLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready."
                android:textColor="#FF00FF00"
                android:textSize="11sp"
                android:typeface="monospace" />

        </ScrollView>

    </LinearLayout>
</ScrollView>
